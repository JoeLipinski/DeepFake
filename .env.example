# --- Backend ---
ENV=production
MAX_UPLOAD_MB=20
JOB_TTL_HOURS=24
CUDA_VISIBLE_DEVICES=0
# Number of uvicorn workers (keep low: GPU is shared, OOM risk with >2)
WORKERS=1
# HuggingFace model IDs
DEPTH_MODEL_ID=depth-anything/Depth-Anything-V2-Large-hf
REALESRGAN_MODEL_URL=https://github.com/xinntao/Real-ESRGAN/releases/download/v0.1.0/RealESRGAN_x4plus.pth
# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:80,http://localhost:5173

# --- Frontend (injected at Vite build time) ---
VITE_API_BASE_URL=http://localhost:80
